rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get the current user's profile
    function getCurrentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && getCurrentUser().role == 'admin';
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admins can read/write everyone's profile
      allow read, write: if isAdmin();
    }
    
    // --- Shipments Collection ---
    match /shipments/{shipmentId} {
      // Anyone can create a shipment (since guests might request a quote/book)
      // Actually, if we require login to book:
      allow create: if request.auth != null;
      
      // Users can only read/update their own shipments
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Admins can read, update, delete all shipments
      allow read, write: if isAdmin();
      
      // Allow reading by tracking number (requires a query, so we need to allow read if trackingNumber matches, 
      // but Firestore rules don't easily filter by query contents securely without complex setups. 
      // For now, allow read if they know the exact document ID or if they are the owner)
      allow read: if true; // Temporarily allow public read for tracking functionality. In production, we'd secure this better.
    }
    
    // --- Testimonials Collection ---
    match /testimonials/{testimonialId} {
      // Anyone can read testimonials
      allow read: if true;
      // Only admins can write/delete
      allow write: if isAdmin();
    }
    
    // --- Messages/Support Collection ---
    match /messages/{messageId} {
      // Users can read/write messages where they are the sender
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      
      // Admins can read/write all messages
      allow read, write: if isAdmin();
    }
    
    // --- Default Deny ---
    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
